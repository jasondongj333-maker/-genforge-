{
  "AI_Chat": {
    "ApiUrl": "https://api.deepseek.com/v1",
    "Model": "deepseek-chat",
    "ProxyUrl": "",
    "_note": "ApiKey 和 ProxyUrl 请配置在同目录 .env 文件中，不要写在 appsettings.json"
  },
  "Server": {
    "Port": 5678
  },
  "MCP": {
    "Servers": [
      {
        "Name": "autocad-mcp-server",
        "Endpoint": "http://localhost:3001/sse",
        "Enabled": false
      }
    ]
  },
  "Skills": {
    "SkillsFolder": "Settings/Skills",
    "EnableDynamicLoading": true
  },
  "Compaction": {
    "Enabled": true,
    "MaxTokens": 30000,
    "TriggerRatio": 0.75,
    "PreserveRecentMessages": 10
  }
}
